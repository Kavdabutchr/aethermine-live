# AetherMine — Environment Variables
# Copy this file, fill in real values, rename to .env
# NEVER commit .env to git — it is blocked by .gitignore

# ─── Required ─────────────────────────────────────────────────────────────────
# Get from BotFather → /mybots → API Token
BOT_TOKEN=

# Get from Render dashboard → your Postgres service → Connection String
DATABASE_URL=

# Choose a strong password for the admin dashboard
ADMIN_PASSWORD=

# ─── Optional (auto-generated if not set) ─────────────────────────────────────
# A random secret Telegram uses to sign webhook requests.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=
